# Supabase credentials — copy this file to ".env" and fill in.
# Find these in Supabase: Project Settings > API

# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# service_role key (SECRET) — used ONLY by local Claude-side scripts.
# Bypasses Row Level Security. Never put this in the Android app.
SUPABASE_SERVICE_KEY=

# anon / public key — used by the Android app (safe to embed in the APK).
SUPABASE_ANON_KEY=
